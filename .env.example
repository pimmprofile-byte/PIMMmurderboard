# ── AI 백엔드 선택 ──
# claude = Claude API (기본, 한국어·연기 최상, 종량 과금)
# ollama = 로컬 무료 모델 (오프라인, 한국어는 qwen2.5 권장)
LLM_BACKEND=claude

# ── Claude API (키는 서버측에만 보관 · 브라우저에 절대 노출 금지) ──
ANTHROPIC_API_KEY=sk-ant-...
# 빠르고 저렴하게 돌리려면 claude-sonnet-5 로 바꿔도 됩니다.
REUNION_MODEL=claude-opus-4-8

# ── 로컬 Ollama (LLM_BACKEND=ollama 일 때만) ──
# 설치: https://ollama.com  →  ollama pull qwen2.5
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5

# ── 서버 ──
# 0.0.0.0 = 같은 와이파이의 다른 기기(폰·PC)에서 접속 허용
# 127.0.0.1 로 두면 이 컴퓨터에서만 접속 가능
REUNION_HOST=0.0.0.0
REUNION_PORT=8790
